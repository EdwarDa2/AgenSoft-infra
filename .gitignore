# ============================================
# .gitignore - Sistema de Citas Médicas
# ============================================

# ============================================
# ARCHIVOS SENSIBLES Y CONFIGURACIÓN
# ============================================
.env
.env.local
.env.development
.env.development.local
.env.test.local
.env.production.local
.env.production

# Secrets y claves
*.pem
*.key
*.cert
secrets/
.secrets

# ============================================
# NODE.JS Y NPM
# ============================================
# Dependencias
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Archivos de lockeo (elegir uno)
# Si usas npm, descomenta:
# package-lock.json
# Si usas yarn, descomenta:
# yarn.lock
# Si usas pnpm, descomenta:
# pnpm-lock.yaml

# Caché de npm/yarn/pnpm
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ============================================
# NEXT.JS (FRONTEND)
# ============================================
# Build outputs
.next/
out/
build/
dist/

# Next.js cache
.next/cache/

# Vercel
.vercel

# ============================================
# REACT Y TYPESCRIPT
# ============================================
# TypeScript cache
*.tsbuildinfo
next-env.d.ts

# ESLint cache
.eslintcache

# ============================================
# DOCKER
# ============================================
# No ignorar docker-compose.yml ni Dockerfiles
# Pero sí ignorar overrides locales
docker-compose.override.yml
docker-compose.local.yml

# Logs de Docker
docker-compose.log

# ============================================
# BASE DE DATOS
# ============================================
# Datos de PostgreSQL (solo en desarrollo local)
pgdata/
postgres-data/

# Dumps de base de datos (pueden ser muy pesados)
*.sql.gz
*.dump
*.backup

# Archivos de migración compilados (según tu ORM)
# Prisma:
# migrations/**/*.sql
# TypeORM:
# src/migrations/*.js

# ============================================
# REDIS
# ============================================
redis-data/
dump.rdb
appendonly.aof

# ============================================
# LOGS
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Logs de aplicación
api/logs/
frontend/logs/
app.log
error.log
combined.log
access.log

# ============================================
# SISTEMA OPERATIVO
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ============================================
# IDEs Y EDITORES
# ============================================
# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# IntelliJ IDEA / WebStorm
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ============================================
# TESTING
# ============================================
# Coverage reports
coverage/
*.lcov
.nyc_output
lib-cov

# Jest
jest-coverage/

# Cypress
cypress/videos/
cypress/screenshots/

# ============================================
# BUILDS Y COMPILADOS
# ============================================
dist/
build/
*.min.js
*.min.css

# Archivos temporales de build
.tmp/
.temp/
tmp/
temp/

# ============================================
# PRISMA (Si usas Prisma ORM)
# ============================================
# No ignorar schema.prisma ni carpeta prisma/
# Pero sí el cliente generado si está fuera de node_modules
# .prisma/

# ============================================
# UPLOADS Y ARCHIVOS DE USUARIO
# ============================================
# Archivos subidos por usuarios
uploads/
public/uploads/
storage/

# Excepto placeholders
!uploads/.gitkeep
!public/uploads/.gitkeep

# ============================================
# CERTIFICADOS SSL (desarrollo local)
# ============================================
*.pem
*.crt
*.key
ssl/
certs/

# ============================================
# BACKUPS
# ============================================
backup/
*.backup
*.bak
*.old

# ============================================
# CACHE
# ============================================
.cache/
*.cache

# Turbo
.turbo

# Parcel
.parcel-cache

# ============================================
# MISCELLANEOUS
# ============================================
# Archivos de sistema
.Spotlight-V100
.Trashes

# Archivos temporales
*.swp
*.swo
*~
.*.swp

# Debug
npm-debug.log*
yarn-debug.log*

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# dotenv environment variable files
.env.*.local

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ============================================
# ARCHIVOS QUE SÍ DEBES INCLUIR (WHITELIST)
# ============================================
# Asegúrate de NO ignorar estos archivos importantes:
# !.gitkeep
# !.env.example
# !docker-compose.yml
# !Dockerfile
# !README.md
# !package.json
# !tsconfig.json

# ============================================
# PGADMIN
# ============================================
pgadmin-data/

# ============================================
# DOCUMENTACIÓN GENERADA
# ============================================
# Si usas herramientas de documentación automática
docs/generated/
api-docs/
.docusaurus/

# ============================================
# MONOREPO (Si usas Turborepo, Nx, etc.)
# ============================================
# Turborepo
.turbo

# Nx
.nx/cache

# ============================================
# TESTING E2E
# ============================================
# Playwright
test-results/
playwright-report/
playwright/.cache/

# ============================================
# ANALYTICS Y REPORTES
# ============================================
.lighthouseci/
bundle-analyzer-report.html

# ============================================
# STORYBOOK
# ============================================
storybook-static/

# ============================================
# HUSKY (Git hooks)
# ============================================
.husky/_

# ============================================
# ARCHIVOS ESPECÍFICOS DEL PROYECTO
# ============================================
# Agrega aquí archivos específicos de tu proyecto

# Ejemplo: Scripts de desarrollo personal
scripts/personal/
scripts/dev-utils/

# Notas de desarrollo personal
NOTES.md
TODO.md
PERSONAL_TODO.md

# ============================================
# FIN DEL .gitignore
# ============================================